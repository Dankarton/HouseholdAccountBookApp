<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 選択状態 -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/> <!-- 背景は透明 -->
            <stroke android:width="3dp" android:color="#FFFFFF"/> <!-- 緑の枠 -->
            <corners android:radius="2dp"/>
        </shape>
    </item>

    <!-- 非選択状態 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/> <!-- 背景は透明 -->
            <stroke android:width="2dp" android:color="#666666"/> <!-- 薄い枠 -->
            <corners android:radius="2dp"/>
        </shape>
    </item>
</selector>