<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="48dp">
    <!-- Settingタブに支出や収入のデータを一覧表示するときに使うアイテム -->

    <!--内容を見やすくするための背景-->
    <View
        android:id="@+id/view2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="2dp"
        android:background="@color/item_background"
        tools:layout_editor_absoluteX="2dp"
        tools:layout_editor_absoluteY="2dp">
    </View>

    <!--カテゴリ欄-->
    <TextView
        android:id="@+id/category_text_view"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="カテゴリ"
        android:textSize="24sp"
        android:gravity="center"
        android:layout_marginLeft="10dp"
        app:layout_constraintBottom_toBottomOf="@id/view2"
        app:layout_constraintStart_toEndOf="@+id/view2"
        app:layout_constraintStart_toStartOf="@+id/view2"
        app:layout_constraintTop_toTopOf="@id/view2" />

    <!--削除ボタン-->
    <ImageButton
        android:id="@+id/more_action_button"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@null"
        android:scaleType="fitCenter"
        android:layout_marginRight="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/category_text_view"
        app:layout_constraintEnd_toEndOf="@+id/view2"
        app:layout_constraintTop_toTopOf="@+id/category_text_view"
        app:srcCompat="@drawable/delete_24px" />

    <!--円(固定テキスト)-->
    <TextView
        android:id="@+id/textView2"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="0dp"
        android:gravity="center_vertical|center_horizontal"
        android:text="@string/yen_in_japanese"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/category_text_view"
        app:layout_constraintEnd_toStartOf="@+id/more_action_button"
        app:layout_constraintTop_toTopOf="@+id/category_text_view" />

    <!--金額欄-->
    <TextView
        android:id="@+id/amount_text_view"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:gravity="right|center_vertical"
        android:text="-4,000,000"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@+id/category_text_view"
        app:layout_constraintEnd_toStartOf="@+id/textView2"
        app:layout_constraintTop_toTopOf="@+id/category_text_view" />

    <!--日付欄-->
    <TextView
        android:id="@+id/date_text_view"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginStart="8dp"
        android:gravity="center_vertical"
        android:text="日付"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@+id/category_text_view"
        app:layout_constraintTop_toTopOf="@+id/category_text_view" />

    <!--メモ欄-->
    <TextView
        android:id="@+id/memo_text_view"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:gravity="center_vertical"
        android:text="PlayStationネットワーク"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/category_text_view"
        app:layout_constraintEnd_toStartOf="@+id/amount_text_view"
        app:layout_constraintStart_toEndOf="@+id/category_text_view"
        app:layout_constraintTop_toBottomOf="@+id/date_text_view" />

</androidx.constraintlayout.widget.ConstraintLayout>