<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/custom_view_item_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <View
        android:id="@+id/item_background"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <View
        android:id="@+id/category_color_dot"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/circle_dot"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toStartOf="@+id/item_background"
        app:layout_constraintTop_toTopOf="@+id/category_text"
        app:layout_constraintBottom_toBottomOf="@+id/category_text"
        />
    <TextView
        android:id="@+id/category_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:text="食費"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@+id/category_color_dot"
        app:layout_constraintTop_toTopOf="@+id/item_background"
        app:layout_constraintBottom_toBottomOf="@+id/item_background"
        />
</androidx.constraintlayout.widget.ConstraintLayout>