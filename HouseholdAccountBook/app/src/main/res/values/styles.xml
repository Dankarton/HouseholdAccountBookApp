<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BottomNavigationViewStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <!-- 背景色 -->
        <item name="android:background">#1A1A1A</item>
        <!-- アイコン・テキストの色 -->
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <!-- 選択時背景色 -->
<!--        <item name="itemBackground">@color/bottom_nav_item_background</item>-->
        <item name="itemBackground">@drawable/bottom_nav_ripple</item>
        <item name="rippleColor">#333333</item>
    </style>
    <style name="NavTabLayoutStyle" parent="Widget.MaterialComponents.TabLayout">
        <!-- 背景色 -->
        <item name="android:background">#1A1A1A</item>
        <!-- アイコン・テキストの色 -->
        <item name="tabTextColor">@color/bottom_nav_item_color</item>
        <item name="tabIconTint">@color/bottom_nav_item_color</item>
        <!-- 選択時背景色 -->
        <item name="tabIndicatorColor">@color/bottom_nav_item_background</item>

        <item name="rippleColor">#333333</item>
    </style>
</resources>

