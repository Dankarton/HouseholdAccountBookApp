<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".HouseHoldApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HouseholdAccountBook"
        tools:targetApi="31">
        <activity
            android:name=".activities.settings.edit.SettingEditPaymentMethodActivity"
            android:exported="false"
            android:label="@string/title_activity_setting_select_payment_method"
            android:theme="@style/Theme.HouseholdAccountBook" />
        <activity
            android:name=".activities.settings.edit.SettingEditIncomeCategoryActivity"
            android:exported="false"/>
        <activity
            android:name=".activities.settings.edit.SettingEditPurchaseCategoryActivity"
            android:exported="false"/>
        <activity
            android:name=".activities.settings.listing.SettingSelectPaymentMethodActivity"
            android:exported="false"
            />
        <activity
            android:name=".activities.settings.listing.SettingSelectIncomeCategoryActivity"
            android:exported="false"/>
        <activity
            android:name=".activities.settings.listing.SettingSelectPurchaseCategoryActivity"
            android:exported="false"/>
        <activity
            android:name=".activities.settings.SettingMotherActivity"
            android:exported="false" />
        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>